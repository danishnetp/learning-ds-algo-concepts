@startuml
' Flowchart for PrintAllDivisors.getDivisors(int N)
title Print All Divisors - Optimal Square Root Approach

start

:Input N;

if (N <= 0?) then (yes)
  :Throw IllegalArgumentException;
  stop
else (no)
endif

:Initialize lower = [];
:Initialize upper = [];
:i = 1;

while ((long)i * i <= N?) is (yes)
  if (N % i == 0?) then (yes)
    :Add i to lower;
    :pair = N / i;
    if (pair != i?) then (yes)
      :Add pair to upper;
    endif
  endif
  :i = i + 1;
endwhile (no)

:Append upper in reverse order to lower;
:return lower;
stop

@enduml

