@startuml
' Flowchart for ZeroSumSubarray.findLongestZeroSumSubarray(int[] A)
title ZeroSumSubarray - Flowchart

start

:Input array A;

if (A == null or A.length == 0?) then (yes)
  :return empty array [];
  stop
else (no)
  :Initialize map = HashMap<Integer, Integer>();
  :currentSum = 0;
  :maxLength = 0;
  :startIdx = -1;
  :endIdx = -1;

  :i = 0;
  while (i < A.length?) is (yes)
    :currentSum = currentSum + A[i];

    if (currentSum == 0?) then (yes)
      :maxLength = i + 1;
      :startIdx = 0;
      :endIdx = i;
    else (no)
      if (map contains currentSum?) then (yes)
        :prevIdx = map.get(currentSum);
        if ((i - prevIdx) > maxLength?) then (yes)
          :maxLength = i - prevIdx;
          :startIdx = prevIdx + 1;
          :endIdx = i;
        else (no)
        endif
      else (no)
        :map.put(currentSum, i);
      endif
    endif

    :i = i + 1;
  endwhile (no)

  if (maxLength > 0?) then (yes)
    :return Arrays.copyOfRange(A, startIdx, endIdx + 1);
  else (no)
    :return empty array [];
  endif

  stop
endif

@enduml

